generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  orders    Order[]
  reviews ProductReview[]
}
enum ProductCategory {
  NOWOSCI
  WYPRZEDAZ
  DOM_I_OGROD
  MOTORYZACJA
  AKCESORIA_DLA_ZWIERZAT
}

enum ProductSubcategory {
  OGROD
  WYPOSAZENIE
}

model Product {
  id           Int                @id @default(autoincrement())
  name         String
  price        Float
  description  String
  image        String
  slug         String             @unique
  isActive     Boolean            @default(true)

  category     ProductCategory    @default(NOWOSCI)
  subcategory  ProductSubcategory?

  orderItems   OrderItem[]
  images       ProductImage[]
  stock        Int                @default(0)
stockStatus  ProductStockStatus @default(BRAK)
reviews ProductReview[]
}
model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  position  Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
}

model Order {
  id            Int           @id @default(autoincrement())
  createdAt     DateTime      @default(now())
  total         Float
  status        OrderStatus   @default(NOWE)

  fullName      String
  email         String
  address       String
  city          String
  postalCode    String

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(OCZEKUJE)

  userId        Int?
  user          User?         @relation(fields: [userId], references: [id])

  items         OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
}

enum OrderStatus {
  NOWE
  W_REALIZACJI
  WYSLANE
}

enum PaymentMethod {
  BLIK
  KARTA
  PRZELEW
  POBRANIE
}

enum PaymentStatus {
  OCZEKUJE
  OPLACONA
  NIEUDANA
}
enum ProductStockStatus {
  DOSTEPNY
  MALO_SZTUK
  BRAK
}
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ProductReview {
  id         Int      @id @default(autoincrement())
  rating     Int
  title      String
  comment    String
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  Int

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
}